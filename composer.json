{
    "name": "netipar/simplepay",
    "description": "Modern Laravel package for SimplePay online payment integration",
    "keywords": ["laravel", "simplepay", "payment", "hungary"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Netipar\\SimplePay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Netipar\\SimplePay\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Netipar\\SimplePay\\SimplePayServiceProvider"
            ],
            "aliases": {
                "SimplePay": "Netipar\\SimplePay\\Facades\\SimplePay"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
